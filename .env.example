IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=you@example.com
IMAP_PASSWORD=app-password
# TLS (default true). Set 0/false only for localhost/plain tests.
IMAP_SECURE=1

# Optional: SQLite path (default ./data/mail.sqlite)
# MAIL_DATABASE_PATH=/path/to/mail.sqlite

# Optional comma-separated folder paths — limit sync/cache to these
# MAILBOXES=INBOX,Sent

# Optional — run sync when MCP process starts (can slow first connection)
# MAIL_SYNC_ON_START=0
